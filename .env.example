# Stock Predictor Configuration
# Copy this file to .env and fill in your API keys

# Application Environment
ENVIRONMENT=development
DEBUG=True

# Database
DATABASE_URL=sqlite:///./data/app.db

# Server
HOST=0.0.0.0
PORT=8000
RELOAD=True

# CORS Origins
CORS_ORIGINS=["http://localhost:3000", "http://localhost:3001", "http://localhost:5173"]

# Security
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# External APIs
# Get your API Key at: https://newsapi.org/
NEWSAPI_API_KEY=your_newsapi_key_here

# Get your API Key at: https://polygon.io/
POLYGON_API_KEY=your_polygon_api_key_here

# Get your API Key at: https://www.alphavantage.co/
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_api_key_here

# ML Model paths
PRICE_PREDICTION_MODEL_PATH=artifacts/models/price_predictor.pkl
RECOMMENDATION_MODEL_PATH=artifacts/models/recommendation.pkl
PRICE_SCALER_PATH=artifacts/scalers/price_scaler.pkl

# Cache
REDIS_URL=redis://localhost:6379
CACHE_EXPIRY_HOURS=24

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/app.log
